{
  "name": "kitchen-ecommerce-backend",
  "version": "1.0.0",
  "description": "Backend for Kitchen E-commerce Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "cleanup:files": "node utils/fileCleanup.js",
    "cleanup:files:dry": "node utils/fileCleanup.js --dry-run",
    "cleanup:stats": "node utils/fileCleanup.js --stats",
    "setup:uploads": "node scripts/setupUploads.js",
    "test:upload": "node scripts/testUpload.js",
    "db:seed": "node scripts/seedData.js",
    "db:migrate": "node scripts/migrate.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "docker:build": "docker build -t your-app .",
    "docker:run": "docker run -p 5000:5000 your-app",
    "docker:compose": "docker-compose up -d",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "security:check": "node scripts/securityCheck.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.812.0",
    "@aws-sdk/s3-request-presigner": "^3.812.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.0",
    "connect-redis": "^8.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.11.2",
    "express-session": "^1.18.1",
    "handlebars": "^4.7.8",
    "helmet": "^6.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.6.1",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.0.3",
    "mongoose-paginate-v2": "^1.9.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^7.0.3",
    "passport": "^0.6.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "rate-limit-redis": "^1.7.0",
    "redis": "^5.0.1",
    "sharp": "^0.34.1",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "eslint": "^8.38.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!client/**"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-console": "off"
    }
  }
}
